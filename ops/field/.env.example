# BIC V2 field deployment — environment template.
#
#   ⚠ THIS FILE IS COMMITTED. It holds ONLY keys + comments — NEVER real secrets.
#   The live file is ops/field/.env (gitignored, 600). Produce it with:
#       ./deploy.sh init-env      # derives shared creds from ~/bic/.env + generates V2 secrets
#   then fill any __FILL_ME__ below and review before `up`.
#
# All five service compose files read this one shared file (env_file: ../.env).
# Values here are the field口径 defaults; the local rehearsal overrides them.

# ============================================================================
# 1. Image tags (from the GHCR docker-build runs — see the P1 image manifest)
# ============================================================================
# Backends share one tag. The portal image is site-agnostic since
# BIC-agent-portal#86 (runtime config via /env.js): latest for steady-state,
# or pin sha-<full sha> to hold a version. Optional per-key overrides
# (PORTAL_STAGE / PORTAL_API_BASE_URL / PORTAL_LAB_API_BASE_URL /
# PORTAL_OIDC_AUTHORITY / PORTAL_OIDC_CLIENT_ID) exist in the portal compose;
# defaults derive from FIELD_HOST + KEYCLOAK_ISSUER_URL and are right for a
# standard site — only set them for exotic topologies.
IMAGE_TAG=main-__FILL_ME__
PORTAL_IMAGE_TAG=latest

# ============================================================================
# 2. Field host / network / shared-infra container names (rarely changed)
# ============================================================================
FIELD_HOST=192.168.12.150
INFRA_NET=infra-net
PG_CONTAINER=bic-postgres
REDIS_CONTAINER=bic-redis
MINIO_CONTAINER=bic-minio
MQ_CONTAINER=bic-rabbitmq

# V2 application container names (must be unique on the host).
KC_CONTAINER_NAME=bic-keycloak
CHEM_CONTAINER_NAME=bic-chem-service
LAB_CONTAINER_NAME=bic-lab-service
BE_CONTAINER_NAME=bic-agent-service
PORTAL_CONTAINER_NAME=bic-agent-portal

# ============================================================================
# 3. Shared infra credentials — init-env DERIVES these from ~/bic/.env.
#    (Confirm the source key names against the real ~/bic/.env at deploy time.)
# ============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__FILL_ME__
REDIS_PASSWORD=__FILL_ME__
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=__FILL_ME__
MQ_USER=rabbitmq
MQ_PASSWORD=__FILL_ME__
MQ_VHOST=/

# ============================================================================
# 4. V2-new secrets — GENERATED ON-SITE by init-env (never leave the machine).
# ============================================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=__FILL_ME__
# BE machine identity (client-credentials) for lab-service calls. ONE value,
# two consumers: the realm import bakes it into the bic-agent-service client,
# and the BE container gets it as KEYCLOAK_CLIENT_SECRET. On a site whose realm
# was imported BEFORE this key existed (orin), add the client once via kcadm
# (see README) with this same secret.
BIC_AGENT_SERVICE_CLIENT_SECRET=__FILL_ME__

# ============================================================================
# 5. Field-only config the operator/Wenlong must supply
# ============================================================================
# Host-local LLM (same posture as V1: model server on host :8000).
BE_LLM_BASE_URL=http://host.docker.internal:8000/v1
BE_LLM_API_KEY=__FILL_ME__
BE_LLM_DEFAULT_MODEL=__FILL_ME__          # must match what the :8000 server serves

# Mind / ChemEngine real field endpoint (ruling 2026-07-11: real, testable).
MIND_HOST=__FILL_ME__
MIND_PORT=8003
MIND_MOCK_MODE=false
MIND_TIMEOUT_SEC=120

# Keycloak issuer — the SAME string for the browser (portal /env.js runtime
# config), the BE, and KC_HOSTNAME. Must be reachable from inside the BE
# container too.
KEYCLOAK_HOSTNAME=http://192.168.12.150:18080
KEYCLOAK_ISSUER_URL=http://192.168.12.150:18080/realms/bic
KEYCLOAK_AUDIENCE=bic-portal
BIC_PORTAL_REDIRECT_URI=http://192.168.12.150:15173/*
BIC_PORTAL_WEB_ORIGIN=http://192.168.12.150:15173

# ============================================================================
# 6. V2 databases / redis indices / buckets (coexist with V1; init-data ensures)
# ============================================================================
BE_PG_DATABASE=talos_agent_db
LAB_PG_DATABASE=labrun_v2_db
KEYCLOAK_DB=keycloak_db
BE_REDIS_DB=3
LAB_REDIS_DB=4
CHEM_REDIS_DB=0
BE_S3_BUCKET=tlc-images
LAB_S3_BUCKET=labrun
CHEM_S3_BUCKET=labassistant
S3_REGION=us-east-1

# --- Cloud-Mind sites: real AWS S3 instead of MinIO (a1 口径, 2026-07-13) ---
# When Mind/ChemEngine is REMOTE (cloud), presigned URLs must be public-internet
# reachable, so ALL S3 writers point at real AWS S3. Uncomment and fill on such
# sites; leave commented on LAN-Mind sites (orin) to keep the MinIO defaults.
# Credentials: dedicated IAM user scoped to the one shared bucket
# (bic-a1-s3, created 2026-07-13; on a1 see ~/.config/bic-v2/s3-bic.env).
#S3_ACCESS_KEY_ID=__FILL_ME__
#S3_SECRET_ACCESS_KEY=__FILL_ME__
#S3_REGION=cn-northwest-1
#BE_S3_ENDPOINT_URL=https://s3.cn-northwest-1.amazonaws.com.cn
#LAB_S3_ENDPOINT_URL=https://s3.cn-northwest-1.amazonaws.com.cn
#CHEM_S3_ENDPOINT_URL=https://s3.cn-northwest-1.amazonaws.com.cn
#MOCK_S3_ENDPOINT=s3.cn-northwest-1.amazonaws.com.cn
#MOCK_S3_SECURE=true
# All four writers share ONE bucket (no key-prefix support in the services —
# object keys carry UUIDs, collision risk accepted, Wenlong ruling 2026-07-13):
#BE_S3_BUCKET=aichemengine-release-bundles
#LAB_S3_BUCKET=aichemengine-release-bundles
#CHEM_S3_BUCKET=aichemengine-release-bundles
#MOCK_S3_BUCKET=aichemengine-release-bundles

# ============================================================================
# 7. Host ports (exclusive V2 ports — deploy.sh preflight checks these free)
# ============================================================================
KEYCLOAK_PORT=18080
CHEM_PORT=8010
LAB_PORT=8192
BE_PORT=8800
PORTAL_PORT=15173

# ============================================================================
# 8. GHCR pull credentials (the TOKEN itself lives ONLY in the file below, 600)
# ============================================================================
GHCR_USER=Valen-C12
GHCR_TOKEN_FILE=~/.config/bic-v2/ghcr.token

# Misc
DEBUG=false
LOG_LEVEL=INFO
TZ=Asia/Shanghai
PHOENIX_ENABLED=false

# TLC develop wait before TLC_OBSERVATION dispatch (robot requirement 2026-07-12:
# 180s physical development). Mock-robot demo sites may lower it (e.g. 30);
# RESTORE 180 when the real robot connects.
TLC_DEVELOP_WAIT_SECONDS=180
