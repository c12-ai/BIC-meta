.playwright-mcp
.DS_Store
.ruff_cache/
.vscode/
.e2e-logs/
CLAUDE.local.md

# Local AI-tool runtime/config overrides.
.claude/.DS_Store
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Project-owned skills. Other synced personal/plugin skills are local noise.
/.claude/skills/*
!/.claude/skills/prd/
!/.claude/skills/prd/SKILL.md
!/.claude/skills/pr-stack/
!/.claude/skills/pr-stack/SKILL.md
!/.claude/skills/gh-stack/
!/.claude/skills/gh-stack/SKILL.md
!/.claude/skills/bic-quality-guan-ping-ce/
!/.claude/skills/bic-quality-guan-ping-ce/**
!/.claude/skills/env-up/
!/.claude/skills/env-up/SKILL.md
!/.claude/skills/s1-triage/
!/.claude/skills/s1-triage/SKILL.md
!/.claude/skills/s2-investigate/
!/.claude/skills/s2-investigate/SKILL.md
/.agents/skills/*
!/.agents/skills/prd
!/.agents/skills/bic-quality-guan-ping-ce/
!/.agents/skills/bic-quality-guan-ping-ce/**

# Generated Python bytecode remains local even inside tracked Skill mirrors.
**/__pycache__/
**/*.pyc
**/*.pyo

# Child repositories are cloned into this workspace but remain independently
# managed Git repositories. The root meta repo tracks only workspace docs,
# Trellis artifacts, scripts, and onboarding files.
/BIC-agent-portal/
/BIC-agent-service/
/BIC-chem-service/
/BIC-lab-service/
/BIC-shared-types/
/mars_interface_mock/
/tech_design/
/tlc-op-builder/

/BIC-infra/
.bic-env

.dispatch/runs/*
